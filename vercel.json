{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/reports/[id]/pdf/route.tsx": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
