// To deploy on Vercel:
//   1. Change `provider` below to "postgresql"
//   2. Set DATABASE_URL to your Vercel/Neon Postgres URL
//   3. Run `npx prisma migrate deploy` (the build script does this automatically)
// No other code or schema change is needed - everything else is portable.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  // Role: ADMIN | QA | VIEWER
  role         String   @default("QA")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reports Report[] @relation("UserReports")
}

model Report {
  id           String   @id @default(cuid())
  title        String
  productName  String
  buildVersion String
  reportDate   DateTime
  preparedBy   String
  summary      String   @default("")
  // ReportStatus: DRAFT | PUBLISHED
  status       String   @default("DRAFT")

  createdById String
  createdBy   User   @relation("UserReports", fields: [createdById], references: [id])

  bugs         Bug[]
  devices      DeviceConfiguration[]
  testResults  TestResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportDate])
  @@index([status])
}

model Bug {
  id         String   @id @default(cuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  jiraId     String
  title      String
  status     String
  // BugPriority: P0 | P1 | P2 | P3 | P4
  priority   String   @default("P3")
  epvFlag    Boolean  @default(false)
  // Platform: MAC_INTEL | MAC_ARM | WINDOWS (nullable)
  platform   String?
  isNewToday Boolean  @default(false)
  owner      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([isNewToday])
}

model DeviceConfiguration {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Platform: MAC_INTEL | MAC_ARM | WINDOWS
  platform  String
  osVersion String
  processor String
  ram       String
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
}

model TestResult {
  id              String   @id @default(cuid())
  reportId        String
  report          Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  testcaseId      String
  testcaseTitle   String
  testsuiteLabel  String
  // TestOutcome: PASS | FAIL | NA | UNTESTED
  macIntelResult  String   @default("UNTESTED")
  macArmResult    String   @default("UNTESTED")
  windowsResult   String   @default("UNTESTED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
}
