# Local dev: SQLite file (no install, zero setup).
# Vercel/prod: paste your Postgres URL here AND change `provider` in
#              prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# NextAuth - generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-please-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
